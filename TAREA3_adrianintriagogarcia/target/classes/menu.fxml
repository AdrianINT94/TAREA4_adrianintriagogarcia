<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="base.controller.MenuController"
      spacing="25.0"
      alignment="CENTER"
      prefWidth="800.0"
      prefHeight="600.0"
      styleClass="root"> <Label text="PANEL DE CONTROL" styleClass="label-titulo" />

    <Button text="Personas" onAction="#irPersonas" prefWidth="250"/>
    <Button text="Artistas" onAction="#irArtistas" prefWidth="250"/>
    <Button text="Espectáculos" onAction="#irEspectaculos" prefWidth="250"/>
    
    
    
    <VBox alignment ="CENTER" style ="-fx-padding:40 0 0 0:">
    <Button text="Salir" onAction="#salir" prefWidth="150" style="-fx-background-color: #d32f2f; -fx-text--fill:white;"/>
    
    </VBox>
    
</VBox>