<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="base.controller.PersonaController">

    <TextField fx:id="txtNombre" promptText="Nombre"/>
    <TextField fx:id="txtEmail" promptText="Email" />
    <TextField fx:id="txtNacionalidad" promptText="Nacionalidad" />
    
    
    
    <Button text="Guardar" onAction="#guardar"/>
    <Button text="Borrar seleccionado" onAction="#borrar"/>

    <ListView fx:id="listaPersonas"/>

</VBox>