<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="base.controller.EspectaculoController"
      spacing="10"
      prefWidth="400">

    <TextField fx:id="txtNombre"
               promptText="Nombre del espectáculo"/>

    <DatePicker fx:id="dpInicio"/>

    <DatePicker fx:id="dpFin"/>

    <ComboBox fx:id="cbCoordinador"
              promptText="Selecciona coordinador"/>

    <Button text="Guardar"
            onAction="#guardar"/>

    <ListView fx:id="listaEspectaculos"/>

</VBox>